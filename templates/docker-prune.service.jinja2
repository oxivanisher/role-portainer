# {{ ansible_managed }}
[Unit]
Description=Remove unused docker resources
Documentation=https://docs.docker.com/v17.09/engine/admin/pruning/
After=docker.service
Requires=docker.service

[Service]
Type=oneshot

# Remove stopped containers, unused networks, dangling + untagged images older than {{ portainer_prune_olderthan }}
ExecStart=/usr/bin/docker system prune --all --force --filter "until={{ portainer_prune_olderthan }}"

# Separately prune build cache older than {{ portainer_prune_olderthan }} (not covered by system prune filter)
ExecStart=/usr/bin/docker builder prune --all --force --filter "until={{ portainer_prune_olderthan }}"

# Prune volumes NOT attached to any container (no age filter available)
# Only anonymous volumes are removed; named volumes survive unless --all is added
ExecStart=/usr/bin/docker volume prune --force

TimeoutSec=10m
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
